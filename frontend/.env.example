# Public API base URL consumed by the browser bundle.
# Local:        http://localhost:4000/api
# Development:   https://dev-api.aletis.me/api
# Production:    https://api.aletis.me/api
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000/api

# Backend origin (for static assets / uploads).
# Local:        http://localhost:4000
# Development:   https://dev-api.aletis.me
# Production:    https://api.aletis.me
NEXT_PUBLIC_BACKEND_URL=http://localhost:4000
